# --- 공개(클라이언트 번들에 인라인; 로컬·CI 빌드용) ---
# 카카오맵: JavaScript 키. /api/kakao-map-config 는 NEXT_PUBLIC_KAKAO_MAP_JS_KEY → NEXT_PUBLIC_KAKAO_MAP_KEY → KAKAO_MAP_JS_KEY 순으로 첫 유효값을 사용합니다.
# - CI/로컬 빌드: NEXT_PUBLIC_KAKAO_MAP_JS_KEY 권장
# - Pages에만 넣기: KAKAO_MAP_JS_KEY (단, 위 NEXT_PUBLIC_* 와 동시에 있으면 NEXT_PUBLIC 이 우선)
#KAKAO_MAP_JS_KEY=
NEXT_PUBLIC_KAKAO_MAP_JS_KEY=your_kakao_javascript_key_here
# "true" 일 때만 관리자 NFC 쓰기 화면에서 "앱(딥링크) 쓰기" 사용 가능(서버에 NFC_NATIVE_HANDOFF_SECRET도 필요)
NEXT_PUBLIC_NFC_NATIVE_HANDOFF_ENABLED=false
# "true" 일 때만 공개 /wayfinder 및 대시보드 동행 화면의 상세(베타) 블록 활성(미설정·false면 공개 404·대시보드는 준비 안내)
NEXT_PUBLIC_WAYFINDER_ENABLED=false
NEXT_PUBLIC_NFC_NATIVE_APP_STORE_URL=
# 배포 URL(선택). 원점(advisory) 안내·딥링크 일관성에 사용. 운영 기준값: https://wow-linku.co.kr
NEXT_PUBLIC_APP_URL=

# --- 서버 전용(리포·CI에 실값 넣지 말 것) ---
# 검색엔진 소유권 확인용(선택)
# GOOGLE_SITE_VERIFICATION=
# NAVER_SITE_VERIFICATION=
# 카카오 로컬 REST API 키 (coord2address — 보호자 알림에 도로명/지번 주소 표시). JavaScript 키와 별도
#KAKAO_REST_API_KEY=
# 딥링크 핸드오프 HMAC. Cloudflare Pages → 프로젝트 → Settings → Environment variables(Production)에 암호화 저장
# 없으면 prepareNfcNativeHandoff 는 "NFC_NATIVE_HANDOFF_SECRET이 설정되지 않았습니다."
#NFC_NATIVE_HANDOFF_SECRET=
